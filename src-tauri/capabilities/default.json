{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for AC Mod Retexture Tool",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:webview:allow-create-webview-window",
    "store:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "realesrgan-ncnn-vulkan", "sidecar": true }]
    }
  ]
}