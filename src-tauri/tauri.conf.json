{
  "productName": "AC Mod Retexture Tool",
  "version": "0.1.0",
  "identifier": "com.volchan.ac-mod-retexture-tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "AC Mod Retexture Tool",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/upscayl-bin"],
    "resources": {
      "resources/models/*": "models/"
    }
  }
}
